# Copy to .env and fill in. .env itself is gitignored.

POSTGRES_DB=semanticlens
POSTGRES_USER=semanticlens
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

ES_PORT=9200
# Single node, local dev only — see docker-compose.yml for why security/HA are off (C4 boundary: no ES cluster).
ES_JAVA_OPTS=-Xms1g -Xmx1g

# Optional: raises Socrata's anonymous rate limit. Get one free at
# https://data.cityofnewyork.us/profile/edit/developer_settings
SOCRATA_APP_TOKEN=
